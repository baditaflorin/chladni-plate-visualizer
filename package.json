{
  "name": "chladni-plate-visualizer",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Interactive WebGPU cymatics lab for vibrating plates, resonant sand patterns, and audio-driven spatial modes.",
  "homepage": "https://baditaflorin.github.io/chladni-plate-visualizer/",
  "repository": {
    "type": "git",
    "url": "https://github.com/baditaflorin/chladni-plate-visualizer.git"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "node scripts/build-info.mjs && vite build && node scripts/copy-404.mjs",
    "preview": "node scripts/serve-pages.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check . && tsc --noEmit",
    "fmt": "prettier --write .",
    "smoke": "bash scripts/smoke.sh"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.172.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
