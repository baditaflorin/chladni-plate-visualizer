#!/usr/bin/env bash
set -euo pipefail

msg_file="${1:-}"
if [[ -z "$msg_file" || ! -f "$msg_file" ]]; then
  echo "commit-msg hook requires a commit message file" >&2
  exit 1
fi

first_line="$(head -n 1 "$msg_file")"
if [[ ! "$first_line" =~ ^(feat|fix|docs|chore|refactor|test|ops|data)(\([a-zA-Z0-9_-]+\))?:\ .+ ]]; then
  echo "Commit message must use Conventional Commits." >&2
  echo "Got: $first_line" >&2
  exit 1
fi
